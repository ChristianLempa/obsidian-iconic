{
	"name": "iconic-custom",
	"version": "0.0.3",
	"description": "Better icon customization with Simple Icons and Devicon support.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"generate:icons": "node scripts/generate-icon-library-data.mjs",
		"build": "npm run generate:icons && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"ci": "npm run build && npm run version:check",
		"version:check": "node scripts/check-version.mjs",
		"release:notes": "node scripts/extract-release-notes.mjs"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"icon",
		"icons",
		"simple-icons",
		"devicon"
	],
	"author": "Christian Lempa",
	"license": "MIT-0",
	"devDependencies": {
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.40.0",
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "8.58.0",
		"@typescript-eslint/parser": "8.58.0",
		"esbuild": "^0.27.4",
		"obsidian": "^1.12.3",
		"tslib": "2.8.1",
		"typescript": "6.0.2"
	},
	"dependencies": {
		"@iconify-json/devicon": "^1.2.62",
		"@iconify-json/simple-icons": "^1.2.87",
		"fflate": "^0.8.3"
	}
}
